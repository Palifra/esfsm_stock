<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List view for material lines -->
    <record id="esfsm_job_material_view_list" model="ir.ui.view">
        <field name="name">esfsm.job.material.list</field>
        <field name="model">esfsm.job.material</field>
        <field name="arch" type="xml">
            <list string="Материјали" editable="bottom">
                <field name="product_id"/>
                <field name="product_tracking" column_invisible="1"/>
                <field name="primary_lot_id" optional="show"
                       string="Лот"
                       invisible="product_tracking == 'none'"/>
                <field name="lot_allocation_historical_gap" optional="hide"
                       invisible="product_tracking == 'none'"/>
                <field name="product_uom_id" groups="uom.group_uom"/>
                <field name="planned_qty"/>
                <field name="taken_qty" readonly="1" decoration-info="taken_qty > 0"/>
                <field name="used_qty" readonly="1" decoration-success="used_qty > 0"/>
                <field name="returned_qty" readonly="1" decoration-muted="returned_qty > 0"/>
                <field name="available_to_return_qty" decoration-warning="available_to_return_qty > 0"/>
                <field name="price_unit" widget="monetary"/>
                <field name="price_subtotal" widget="monetary"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="company_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Form view for material lines -->
    <record id="esfsm_job_material_view_form" model="ir.ui.view">
        <field name="name">esfsm.job.material.form</field>
        <field name="model">esfsm.job.material</field>
        <field name="arch" type="xml">
            <form string="Материјал">
                <sheet>
                    <group>
                        <group>
                            <field name="job_id"/>
                            <field name="product_id"/>
                            <field name="product_tracking" invisible="1"/>
                            <field name="primary_lot_id" readonly="1"
                                   invisible="product_tracking == 'none'"/>
                            <field name="product_uom_id" groups="uom.group_uom"/>
                            <field name="price_unit" widget="monetary"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="manual_lot_selection"
                                   invisible="product_tracking == 'none'"
                                   widget="boolean_toggle"/>
                            <field name="lot_allocation_historical_gap" readonly="1"
                                   invisible="not lot_allocation_historical_gap"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="company_id" invisible="1"/>
                        </group>
                    </group>
                    <group string="Количини">
                        <group>
                            <field name="planned_qty"/>
                            <field name="taken_qty" readonly="1"/>
                        </group>
                        <group>
                            <field name="used_qty" readonly="1"/>
                            <field name="returned_qty" readonly="1"/>
                            <field name="available_to_return_qty"/>
                        </group>
                    </group>
                    <div class="alert alert-info" role="alert">
                        <strong>Информација:</strong> Полињата Земено, Искористено и Вратено се менуваат
                        преку копчињата "Превземи", "Потроши" и "Врати" во работниот налог.
                    </div>
                    <div class="alert alert-warning" role="alert"
                         invisible="not lot_allocation_historical_gap">
                        <i class="fa fa-exclamation-triangle"/>
                        <strong>Историски пропуст:</strong> Материјалот е земен пред воведување
                        на lot allocation tracking. Лотовите не се забележани.
                    </div>
                    <notebook invisible="product_tracking == 'none'">
                        <page string="Алокации по лот" name="lot_allocations">
                            <field name="lot_allocation_ids">
                                <list editable="bottom" limit="5">
                                    <field name="lot_id" required="1"/>
                                    <field name="taken_qty"/>
                                    <field name="used_qty" readonly="1"/>
                                    <field name="returned_qty" readonly="1"/>
                                    <field name="available_to_consume_qty" readonly="1"
                                           decoration-success="available_to_consume_qty > 0"/>
                                    <field name="available_to_return_qty" readonly="1"
                                           decoration-warning="available_to_return_qty > 0"/>
                                </list>
                            </field>
                            <group col="4">
                                <field name="taken_qty_per_lot_sum" readonly="1"/>
                                <field name="used_qty_per_lot_sum" readonly="1"/>
                                <field name="returned_qty_per_lot_sum" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                    <group>
                        <field name="price_subtotal" widget="monetary"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view for material lines -->
    <record id="esfsm_job_material_view_search" model="ir.ui.view">
        <field name="name">esfsm.job.material.search</field>
        <field name="model">esfsm.job.material</field>
        <field name="arch" type="xml">
            <search string="Материјали">
                <field name="product_id"/>
                <field name="job_id"/>
                <group expand="0" string="Групирај по">
                    <filter string="Производ" name="group_product" context="{'group_by': 'product_id'}"/>
                    <filter string="Работа" name="group_job" context="{'group_by': 'job_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action for material lines -->
    <record id="esfsm_job_material_action" model="ir.actions.act_window">
        <field name="name">Материјали</field>
        <field name="res_model">esfsm.job.material</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Креирајте нова ставка за материјал
            </p>
            <p>
                Овде можете да го следите животниот циклус на материјалите:<br/>
                • Планирано - Проценета количина<br/>
                • Земено - Количина земена од магацин<br/>
                • Искористено - Количина потрошена на работа<br/>
                • Вратено - Неискористена количина вратена назад
            </p>
        </field>
    </record>
</odoo>
