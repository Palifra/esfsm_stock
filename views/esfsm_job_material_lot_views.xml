<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="esfsm_job_material_lot_view_list" model="ir.ui.view">
        <field name="name">esfsm.job.material.lot.list</field>
        <field name="model">esfsm.job.material.lot</field>
        <field name="arch" type="xml">
            <list string="Алокации по лот">
                <field name="job_id"/>
                <field name="product_id"/>
                <field name="lot_id"/>
                <field name="taken_qty"/>
                <field name="used_qty"/>
                <field name="returned_qty"/>
                <field name="available_to_consume_qty"/>
                <field name="available_to_return_qty"/>
                <field name="product_uom_id" groups="uom.group_uom"/>
                <field name="company_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="esfsm_job_material_lot_view_form" model="ir.ui.view">
        <field name="name">esfsm.job.material.lot.form</field>
        <field name="model">esfsm.job.material.lot</field>
        <field name="arch" type="xml">
            <form string="Алокација по лот">
                <sheet>
                    <group>
                        <group>
                            <field name="material_id"/>
                            <field name="job_id" readonly="1"/>
                            <field name="product_id" readonly="1"/>
                            <field name="lot_id"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="product_uom_id" readonly="1"/>
                        </group>
                    </group>
                    <group string="Количини">
                        <group>
                            <field name="taken_qty"/>
                            <field name="used_qty"/>
                            <field name="returned_qty"/>
                        </group>
                        <group>
                            <field name="available_to_consume_qty" readonly="1"/>
                            <field name="available_to_return_qty" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="esfsm_job_material_lot_view_search" model="ir.ui.view">
        <field name="name">esfsm.job.material.lot.search</field>
        <field name="model">esfsm.job.material.lot</field>
        <field name="arch" type="xml">
            <search string="Алокации по лот">
                <field name="lot_id"/>
                <field name="product_id"/>
                <field name="job_id"/>
                <filter string="Има за трошење" name="to_consume"
                        domain="[('available_to_consume_qty', '>', 0)]"/>
                <filter string="Има за враќање" name="to_return"
                        domain="[('available_to_return_qty', '>', 0)]"/>
                <group expand="0" string="Групирај по">
                    <filter string="Производ" name="group_product"
                            context="{'group_by': 'product_id'}"/>
                    <filter string="Работа" name="group_job"
                            context="{'group_by': 'job_id'}"/>
                    <filter string="Лот" name="group_lot"
                            context="{'group_by': 'lot_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="esfsm_job_material_lot_action" model="ir.actions.act_window">
        <field name="name">Алокации по лот</field>
        <field name="res_model">esfsm.job.material.lot</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Овде се прикажуваат алокациите на лотови по материјал на работен налог.
            </p>
        </field>
    </record>
</odoo>
